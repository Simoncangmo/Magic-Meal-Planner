/* app.wxss - 全局样式 */

/* CSS 变量 */
page {
  --color-primary: #4CAF82;
  --color-primary-light: #E8F5EF;
  --color-primary-dark: #388E5C;
  --color-accent: #FF8A50;
  --color-accent-light: #FFF0E8;
  --color-bg: #F5F7FA;
  --color-card: #FFFFFF;
  --color-text: #1A2332;
  --color-text-secondary: #6B7A8D;
  --color-text-light: #A8B4C0;
  --color-border: #E8EDF2;
  --color-breakfast: #FFD84D;
  --color-lunch: #4CAF82;
  --color-dinner: #FF8A50;
  --color-error: #FF5252;
  --color-warning: #FFC107;
  --color-info: #4DA6FF;
  
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;
  
  --shadow-sm: 0 2rpx 12rpx rgba(0,0,0,0.06);
  --shadow-md: 0 4rpx 24rpx rgba(0,0,0,0.10);
  --shadow-lg: 0 8rpx 40rpx rgba(0,0,0,0.14);
  
  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: var(--color-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
}

/* 安全区域底部 */
.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 0 0 env(safe-area-inset-bottom);
}

/* 按钮 */
.btn-primary {
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: var(--radius-full);
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 130, 0.35);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: var(--color-primary-light);
  color: var(--color-primary);
  border-radius: var(--radius-full);
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: none;
}

.btn-secondary::after {
  border: none;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 500;
}

.tag-green {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.tag-orange {
  background: var(--color-accent-light);
  color: var(--color-accent);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 24rpx 0;
}

/* 输入框 */
.input-field {
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--color-text);
  transition: border-color 0.2s;
}

.input-field:focus {
  border-color: var(--color-primary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: var(--color-text-light);
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

/* 滚动容器 */
.scroll-content {
  padding: 24rpx 30rpx;
}

/* 节标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  bottom: calc(env(safe-area-inset-bottom) + 160rpx);
  right: 32rpx;
  width: 96rpx;
  height: 96rpx;
  background: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-md);
  z-index: 100;
}

.fab-icon {
  color: #FFFFFF;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 300;
}
